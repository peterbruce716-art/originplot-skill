{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "originplot.semantic_figure_benchmark.v1",
  "type": "object",
  "required": ["schema", "figure_id", "recipe", "source_image", "exports", "expected", "actual"],
  "properties": {
    "schema": {"const": "originplot.semantic_figure_benchmark.v1"},
    "figure_id": {"type": "string", "minLength": 1},
    "recipe": {
      "type": "string",
      "enum": [
        "recipe.schematic.dual_panel_curve.v1",
        "recipe.bar.grouped_stacked_three_panel.v1",
        "recipe.contour.discrete_three_panel.v1"
      ]
    },
    "source_image": {"type": "string", "minLength": 1},
    "exports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "panel": {"type": "string"}
        }
      }
    },
    "expected": {
      "type": "object",
      "properties": {
        "structure": {"type": "object"},
        "data": {"type": "object"},
        "geometry": {"type": "object"},
        "style": {"type": "object"},
        "required_objects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "expected_count"],
            "properties": {
              "role": {"type": "string", "minLength": 1},
              "expected_count": {"type": "integer", "minimum": 0},
              "critical": {"type": "boolean", "default": true}
            }
          }
        },
        "rois": {"type": "array"},
        "visual_thresholds": {"type": "object"}
      }
    },
    "actual": {
      "type": "object",
      "properties": {
        "structure": {"type": "object"},
        "data": {"type": "object"},
        "geometry": {"type": "object"},
        "style": {"type": "object"},
        "objects": {"type": "array"}
      }
    }
  }
}
