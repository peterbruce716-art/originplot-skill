{
  "schema": "originplot.figurespec.v5",
  "figure": {"id": "fig_demo_line", "title": "OriginPlot v5 demo line"},
  "runtime": {
    "project_path": "outputs/origin_v5_demo/fig_demo_line.opju",
    "pre_save_export": "outputs/origin_v5_demo/fig_demo_line_presave.png",
    "post_reopen_export": "outputs/origin_v5_demo/fig_demo_line_postreopen.png"
  },
  "origin": {
    "target_version": "2022",
    "adapter_policy": "capability_driven",
    "primary_graph": "FigDemo_Line",
    "seed_template": "Origin",
    "capability_profile": "capabilities/origin-2022-v5.json",
    "operation_routes": {
      "session": "originpro",
      "data": "originpro",
      "graph": "originpro",
      "plot": "originpro",
      "axis": "originpro",
      "style": "originpro",
      "object": "originpro_labtalk",
      "export": "originpro",
      "save": "originpro",
      "reopen": "inspection",
      "inspect": "inspection",
      "qa": "evidence_qa"
    }
  },
  "data": [
    {
      "id": "line_data",
      "origin_name": "FigDemo_Data",
      "source": "examples/data/fig_demo_line.csv",
      "roles": {"x": "Temperature", "y": "Stress"}
    }
  ],
  "page": {"size_mm": [120, 80]},
  "layers": [
    {
      "id": "panel_a",
      "origin_name": "Panel_A",
      "position_abs_mm": [18, 14, 88, 54],
      "x": {"scale": "linear", "limits": [250, 400], "label": "Temperature / degC"},
      "y": {"scale": "linear", "limits": [0, 120], "label": "Stress / MPa"}
    }
  ],
  "plots": [
    {
      "id": "stress_curve",
      "layer": "panel_a",
      "data_ref": "line_data",
      "type": "line",
      "map": {"x": "Temperature", "y": "Stress"},
      "style": {"line_color": "#1f4e9d", "line_width_pt": 1.2}
    }
  ],
  "annotations": [],
  "contracts": {
    "primary_graph": "FigDemo_Line",
    "expected": {"graph_pages": 1, "layers": 1, "plots": 1, "workbooks": 1},
    "prohibited_on_primary": {
      "raster_source_image": true,
      "unnamed_objects": true,
      "placeholder_plots": true,
      "auto_rescale_after_annotations": true
    }
  }
}
